# Backend environment variables — copy this to .env

# ── Supabase ───────────────────────────────────────────────────────────────────
# Settings → API → Project URL
SUPABASE_URL=https://your-project.supabase.co

# Settings → API → Publishable key (was "anon key")
# Used server-side to proxy auth calls to Supabase — never exposed to browser
SUPABASE_ANON_KEY=eyJ...your-publishable-key...

# ── Direct DB connection ───────────────────────────────────────────────────────
# Settings → Database → Connect → Session Pooler → URI
# Change postgresql:// → postgresql+asyncpg://
DATABASE_URL=postgresql+asyncpg://postgres.PROJECTREF:PASSWORD@aws-0-ap-south-1.pooler.supabase.com:6543/postgres

# ── App ────────────────────────────────────────────────────────────────────────
DEBUG=true
CORS_ORIGINS=["http://localhost:5173","http://localhost:3000"]
